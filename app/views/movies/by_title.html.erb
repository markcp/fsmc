<h2><%= @year + " Movies by Title" %></h1>
<div id="submenu">
  <%= link_to @year + " Viewing Log", viewings_path(year: @year) %> |
  <%= link_to @year + " Movies Ranked", by_rating_movies_path(year: @year) %>
</div>

<ul class="movie-list">
<% @movies.each do |movie| %>
  <li>
    <%= movie.display %> <span class="rating"><%= movie.current_rating %></span> <% if signed_in? %><span class="edit-link"><%= link_to 'e', edit_movie_path(movie) %></span><% end %><br/>
  </li>
<% end %>
