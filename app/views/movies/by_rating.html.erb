<h2><%= @year + " Movies Ranked" %></h2>
<div id="submenu">
  <%= link_to @year + " Viewing Log", viewings_path(year: @year) %> |
  <%= link_to @year + " Movies by Title", by_title_movies_path(year: @year) %>
</div>

<% hold_rating = 11 %>
<% @movies.each_with_index do |movie, index| %>
  <% if (movie.current_rating / 10) < hold_rating  && index != 0 %>
    <br/>
  <% end %>
  <% hold_rating = (movie.current_rating / 10) %>
  <%= movie.display %> <span class="rating"><%= movie.current_rating %></span><br/>
<% end %>

