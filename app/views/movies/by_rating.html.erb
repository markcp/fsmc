<h2><%= @year + " Movies Ranked" %></h2>
<div id="submenu">
  <%= link_to @year + " Viewing Log", viewings_path(year: @year) %> |
  <%= link_to @year + " Movies by Title", by_title_movies_path(year: @year) %>
</div>

<ul class="movie-list">
<% @movies.each_with_index do |movie, index| %>
  <li>
    <%= index + 1 %>.
    <%= movie.display %>
    <span class="rating"><%= movie.current_rating %></span>
    <% if signed_in? %>
      <span class="edit-link"><%= link_to 'e', edit_movie_path(movie) %></span>
    <% end %>
  </li>
<% end %>
</ul>
