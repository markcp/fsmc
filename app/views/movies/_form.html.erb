<div class="row">
  <div class="col-md-4 col-md-offset-4">
    <%= form_for(@movie, role: 'form') do |f| %>
      <div class="form-group">
        <%= f.label :title %>
        <%= f.text_field :title, class: 'form-control' %>
      </div>

      <div class="form-group">
        <%= f.label :director %>
        <%= f.text_field :director, class: 'form-control' %>
      </div>

      <div class="form-group">
        <%= f.label :year %>
        <%= f.text_field :year, class: 'form-control' %>
      </div>

      <div class="form-group">
        <%= f.label :skandies_year %>
        <%= f.text_field :skandies_year, class: 'form-control' %>
      </div>

      <div class="form-group">
        <%= f.label :short %>
        <%= f.check_box :short, class: 'form-control' %>
      </div>

      <div class="form-group">
        <%= f.label :current_rating %>
        <%= f.text_field :current_rating, class: 'form-control' %>
      </div>

      <%= f.fields_for :viewings do |vf| %>
        <div class="form-group">
          <%= vf.label :date %>
          <%= vf.text_field :date, class: 'form-control' %>
        </div>

        <div class="form-group">
          <%= vf.label :format_id %>
          <%= vf.text_field :format_id, class: 'form-control' %>
        </div>

        <div class="form-group">
          <%= vf.label :rating %>
          <%= vf.text_field :rating, class: 'form-control' %>
        </div>

        <div class="form-group">
          <%= vf.label :notes %>
          <%= vf.text_area :notes, class: 'form-control' %>
        </div>
      <% end %>

      <%= f.button "Create movie", class: "btn btn-lrg btn-primary" %>
    <% end %>
  </div>
</div>
